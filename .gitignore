cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/

# VS Code
.vscode/

# OS / misc
.DS_Store
Thumbs.db

# Logs
*.log
EOF

# Never commit keys/secrets
github-sdr-key
github-sdr-key.pub

# Common private key patterns
id_ed25519*
id_rsa*
*.pem
*.key